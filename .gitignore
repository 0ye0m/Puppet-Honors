

```gitignore
# Puppet SSL certificates and keys
*.pem
*.key
*.crt
*.csr

# Puppet data directories
/opt/puppetlabs/server/data/
/etc/puppetlabs/puppet/ssl/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log